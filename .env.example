# Queue Service — server configuration
# Priority: this file > OS environment variables > defaults
#
# Uncomment and modify values as needed.
# Lines starting with # are comments.

# ---- Network ----
# PUBLIC_ADDR=0.0.0.0:8080
# INTERNAL_ADDR=127.0.0.1:8081

# ---- Paths ----
# QUEUES_CONFIG_DIR=./configs
# QUEUE_STORAGE_DIR=./data
# STATIC_DIR=web/static

# ---- PHP ----
# PHP_CGI=php-cgi

# ---- Auth ----
# WORKER_TOKEN=
# ALLOW_AUTO_GUID=false

# ---- Storage ----
# STORAGE_OPEN_TIMEOUT_MS=2000
# PROCESSING_TIMEOUT_MS=120000
# GC_PROCESSING_GRACE_MS=120000

# ---- HTTP ----
# READ_HEADER_TIMEOUT_SEC=5

# ---- Shutdown ----
# SHUTDOWN_TIMEOUT_SEC=10
# STOP_ALL_TIMEOUT_SEC=30

# ---- Logging ----
# DISABLE_ACCESS_LOG=false
