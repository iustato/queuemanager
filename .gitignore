# Бинарные файлы и исполняемые файлы Go
/queue-service
/server
/cmd/server/server
/cmd/load_test/load_test
*.exe
*.test
*.prof

# Базы данных и временные данные
/data/*.db
/data/*.db-journal
/data/*.db-shm
/data/*.db-wal

# Логи (самая частая причина "Error during execution" из-за объема)
*.log
/configs/scripts/logs/**/*
/internal/queue/configs/scripts/logs/**/*

# Результаты тестов (если они слишком большие)
# Если вы хотите, чтобы Claude их видел, не добавляйте их сюда,
# но если их десятки — лучше скрыть.
result.txt
run_*.txt

# Системные файлы и зависимости
.DS_Store
node_modules/
/vendor/

# Личные заметки и шпаргалки
AUTO_GUID.txt
BOLT_BD_START.txt
GIT_LAB.txt
LOGS_CLEAR.txt
QUICK_START
TESTS_START.TXT
CODE_REVIEW1.md

# Environment config (keep .env.example tracked)
.env

# Admin panel (Next.js)
/admin/.next/
/admin/out/
/admin/.env*.local